{
  "regions": ["iad1"],
  "functions": {
    "api/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/documents/:id", "destination": "/api/documents/[id].ts" },
    { "source": "/api/employees/:id", "destination": "/api/employees/[id].ts" },
    { "source": "/api/employees", "destination": "/api/employees/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
